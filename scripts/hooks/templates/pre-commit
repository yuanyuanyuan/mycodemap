}

cleanup_temp_artifacts() {
    if [ -n "$CHECK_RESULTS_FILE" ] && [ -f "$CHECK_RESULTS_FILE" ]; then
        rm -f "$CHECK_RESULTS_FILE"
    fi
    if [ -n "$TEST_OUTPUT_FILE" ] && [ -f "$TEST_OUTPUT_FILE" ]; then
        rm -f "$TEST_OUTPUT_FILE"
    fi
    if [ -n "$FILTERED_TEST_OUTPUT_FILE" ] && [ -f "$FILTERED_TEST_OUTPUT_FILE" ]; then
        rm -f "$FILTERED_TEST_OUTPUT_FILE"
    fi
}

trap cleanup_temp_artifacts EXIT

setup_output_mode() {
    exec 3>&1 4>&2
    if [ "$PROTOCOL_ONLY" = "1" ]; then
        PROTOCOL_OUTPUT_MODE="protocol-only"
        exec >/dev/null 2>&1
    fi
}

