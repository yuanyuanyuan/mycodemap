#!/bin/sh
# Pre-commit hook: 运行测试和文件头检查

HOOK_SOURCE=".mycodemap/hooks/pre-commit"
TEST_OUTPUT_FILE=""
FILTERED_TEST_OUTPUT_FILE=""
SUPPRESSED_TEST_WARNING_COUNT=0
FAILED_TEST_FILE=""
FAILED_TEST_HEADLINE=""
FAILED_TEST_HINT=""
FAILED_TEST_VERIFY_COMMAND=""
GENERAL_VERIFY_COMMAND=""
TEST_COMMAND=""
TEST_STRATEGY=""
TEST_FAILURE_REASON=""
TEST_TARGET_KIND=""
SOURCE_FILE_PATTERN=""
PACKAGE_MANAGER=""
PACKAGE_MANAGER_HINT=""
PACKAGE_TEST_COMMAND=""
TEST_SCRIPT=""
VITEST_ARGS=""
JEST_ARGS=""
VITEST_ENTRY=""

print_blocked_rule() {
    rule_id="$1"
    reason="$2"

    echo "ERROR: Commit precheck blocked the commit."
    echo "RULE_ID: $rule_id"
    echo "HOOK_SOURCE: $HOOK_SOURCE"
    echo "WHY: $reason"
}

cleanup_related_test_artifacts() {
    if [ -n "$TEST_OUTPUT_FILE" ] && [ -f "$TEST_OUTPUT_FILE" ]; then
        rm -f "$TEST_OUTPUT_FILE"
    fi
    if [ -n "$FILTERED_TEST_OUTPUT_FILE" ] && [ -f "$FILTERED_TEST_OUTPUT_FILE" ]; then
        rm -f "$FILTERED_TEST_OUTPUT_FILE"
    fi
}

read_package_json_metadata() {
    if [ ! -f "package.json" ]; then
        return 1
    fi

    PACKAGE_JSON_METADATA=$(python3 - <<'PY'
import json
from pathlib import Path

try:
    pkg = json.loads(Path("package.json").read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(1)

scripts = pkg.get("scripts") or {}
package_manager = str(pkg.get("packageManager") or "").strip()
test_script = str(scripts.get("test") or "").strip()

print(package_manager)
print(test_script)
PY
) || return 1

    PACKAGE_MANAGER_HINT=$(printf '%s\n' "$PACKAGE_JSON_METADATA" | sed -n '1p')
    TEST_SCRIPT=$(printf '%s\n' "$PACKAGE_JSON_METADATA" | sed -n '2p')
    return 0
}

resolve_package_manager() {
    PACKAGE_MANAGER=""
    PACKAGE_MANAGER_HINT=""
    TEST_SCRIPT=""

    read_package_json_metadata || true

    case "$PACKAGE_MANAGER_HINT" in
        pnpm@*|pnpm)
            PACKAGE_MANAGER="pnpm"
            ;;
        yarn@*|yarn)
            PACKAGE_MANAGER="yarn"
            ;;
        bun@*|bun)
            PACKAGE_MANAGER="bun"
            ;;
        npm@*|npm)
            PACKAGE_MANAGER="npm"
            ;;
    esac

    if [ -z "$PACKAGE_MANAGER" ]; then
        if [ -f "pnpm-lock.yaml" ]; then
            PACKAGE_MANAGER="pnpm"
        elif [ -f "yarn.lock" ]; then
            PACKAGE_MANAGER="yarn"
        elif [ -f "bun.lockb" ] || [ -f "bun.lock" ]; then
            PACKAGE_MANAGER="bun"
        elif [ -f "package-lock.json" ] || [ -f "package.json" ]; then
            PACKAGE_MANAGER="npm"
        fi
    fi
}

build_package_test_command() {
    case "$PACKAGE_MANAGER" in
        pnpm)
            PACKAGE_TEST_COMMAND="pnpm test"
            ;;
        yarn)
            PACKAGE_TEST_COMMAND="yarn test"
            ;;
        bun)
            PACKAGE_TEST_COMMAND="bun test"
            ;;
        npm|*)
            PACKAGE_TEST_COMMAND="npm test"
            ;;
    esac
}

ensure_vitest_entry() {
    VITEST_ENTRY=""

    if [ -f "node_modules/vitest/vitest.mjs" ]; then
        VITEST_ENTRY="node_modules/vitest/vitest.mjs"
        return 0
    fi

    if [ -d "node_modules" ] && [ ! -e "node_modules/vitest" ]; then
        VITEST_PACKAGE_DIR=$(find node_modules -type d -path '*/.pnpm/*/node_modules/vitest' | head -n 1)
        if [ -n "$VITEST_PACKAGE_DIR" ]; then
            ln -sfn "${VITEST_PACKAGE_DIR#node_modules/}" node_modules/vitest
        fi
    fi

    if [ -f "node_modules/vitest/vitest.mjs" ]; then
        VITEST_ENTRY="node_modules/vitest/vitest.mjs"
        return 0
    fi

    if [ -d "node_modules" ]; then
        VITEST_ENTRY=$(find node_modules -type f -path '*/.pnpm/*/node_modules/vitest/vitest.mjs' | head -n 1)
        if [ -z "$VITEST_ENTRY" ]; then
            VITEST_ENTRY=$(find node_modules -type f -path '*/.vitest-*/vitest.mjs' | head -n 1)
        fi
    fi

    if [ -n "$VITEST_ENTRY" ]; then
        return 0
    fi

    return 1
}

build_vitest_related_command() {
    GENERAL_VERIFY_COMMAND="npx vitest related"
    for staged_file in $STAGED; do
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND $staged_file"
    done
    GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --watch=false --bail=1"
    if [ "$STAGED_COUNT" -gt 3 ]; then
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --pool=forks --poolOptions.forks.singleFork"
    fi
    TEST_COMMAND="$GENERAL_VERIFY_COMMAND"
    VITEST_ARGS=${GENERAL_VERIFY_COMMAND#npx vitest }
}

build_jest_related_command() {
    GENERAL_VERIFY_COMMAND="npx jest --findRelatedTests"
    for staged_file in $STAGED; do
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND $staged_file"
    done
    GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --bail"
    if [ "$STAGED_COUNT" -gt 3 ]; then
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --runInBand"
    fi
    TEST_COMMAND="$GENERAL_VERIFY_COMMAND"
    JEST_ARGS=${GENERAL_VERIFY_COMMAND#npx jest }
}

build_test_precheck_plan() {
    TEST_COMMAND=""
    TEST_STRATEGY=""
    TEST_FAILURE_REASON=""
    TEST_TARGET_KIND=""
    SOURCE_FILE_PATTERN=""
    GENERAL_VERIFY_COMMAND=""
    FAILED_TEST_VERIFY_COMMAND=""
    PACKAGE_TEST_COMMAND=""

    resolve_package_manager

    SOURCE_FILE_PATTERN='\.[cm]?[jt]sx?$'
    TEST_TARGET_KIND="JS/TS source"

    if [ -f "package.json" ]; then
        if echo "$TEST_SCRIPT" | grep -Eq '^vitest([[:space:]].*)?$'; then
            TEST_STRATEGY="vitest-related"
            TEST_FAILURE_REASON="Related Vitest checks for the staged source files failed."
            return 0
        fi

        if echo "$TEST_SCRIPT" | grep -Eq '^jest([[:space:]].*)?$'; then
            TEST_STRATEGY="jest-related"
            TEST_FAILURE_REASON="Related Jest checks for the staged source files failed."
            return 0
        fi

        if [ -z "$TEST_SCRIPT" ] && ensure_vitest_entry; then
            TEST_STRATEGY="vitest-related"
            TEST_FAILURE_REASON="Related Vitest checks for the staged source files failed."
            return 0
        fi

        if [ -n "$TEST_SCRIPT" ]; then
            build_package_test_command
            TEST_STRATEGY="package-test"
            TEST_COMMAND="$PACKAGE_TEST_COMMAND"
            GENERAL_VERIFY_COMMAND="$PACKAGE_TEST_COMMAND"
            TEST_FAILURE_REASON="The project test command for the staged source files failed."
            return 0
        fi
    fi

    if ensure_vitest_entry; then
        TEST_STRATEGY="vitest-related"
        TEST_FAILURE_REASON="Related Vitest checks for the staged source files failed."
        return 0
    fi

    if [ -f "pyproject.toml" ]; then
        TEST_STRATEGY="pytest"
        TEST_TARGET_KIND="Python source"
        SOURCE_FILE_PATTERN='\.py$'
        TEST_COMMAND="pytest"
        GENERAL_VERIFY_COMMAND="pytest"
        TEST_FAILURE_REASON="Pytest failed for the staged source files."
        return 0
    fi

    if [ -f "go.mod" ]; then
        TEST_STRATEGY="go-test"
        TEST_TARGET_KIND="Go source"
        SOURCE_FILE_PATTERN='\.go$'
        TEST_COMMAND="go test ./..."
        GENERAL_VERIFY_COMMAND="go test ./..."
        TEST_FAILURE_REASON="Go tests failed for the staged source files."
        return 0
    fi

    if [ -f "Cargo.toml" ]; then
        TEST_STRATEGY="cargo-test"
        TEST_TARGET_KIND="Rust source"
        SOURCE_FILE_PATTERN='\.rs$'
        TEST_COMMAND="cargo test"
        GENERAL_VERIFY_COMMAND="cargo test"
        TEST_FAILURE_REASON="Cargo tests failed for the staged source files."
        return 0
    fi

    return 1
}

extract_failed_test_file() {
    FAILED_TEST_FILE=""

    case "$TEST_STRATEGY" in
        pytest)
            FAILED_TEST_FILE=$(grep -Eo '([A-Za-z0-9_./-]+/)?(test_[A-Za-z0-9_./-]+\.py|[A-Za-z0-9_./-]+_test\.py)' "$FILTERED_TEST_OUTPUT_FILE" | head -n 1)
            ;;
        go-test)
            FAILED_TEST_FILE=$(grep -Eo '[A-Za-z0-9_./-]+_test\.go' "$FILTERED_TEST_OUTPUT_FILE" | head -n 1)
            ;;
        cargo-test)
            FAILED_TEST_FILE=""
            ;;
        *)
            FAILED_TEST_FILE=$(grep -Eo '[A-Za-z0-9_./-]+\.(test|spec)\.[cm]?[jt]sx?' "$FILTERED_TEST_OUTPUT_FILE" | head -n 1)
            ;;
    esac
}

build_failed_test_verify_command() {
    FAILED_TEST_VERIFY_COMMAND=""

    if [ -z "$FAILED_TEST_FILE" ]; then
        return 0
    fi

    case "$TEST_STRATEGY" in
        vitest-related)
            FAILED_TEST_VERIFY_COMMAND="npx vitest run $FAILED_TEST_FILE"
            ;;
        jest-related)
            FAILED_TEST_VERIFY_COMMAND="npx jest $FAILED_TEST_FILE --runInBand"
            ;;
        pytest)
            FAILED_TEST_VERIFY_COMMAND="pytest $FAILED_TEST_FILE"
            ;;
    esac
}

run_test_precheck_command() {
    case "$TEST_STRATEGY" in
        vitest-related)
            build_vitest_related_command
            if ensure_vitest_entry; then
                node "$VITEST_ENTRY" $VITEST_ARGS >"$TEST_OUTPUT_FILE" 2>&1
            else
                npx --yes vitest $VITEST_ARGS >"$TEST_OUTPUT_FILE" 2>&1
            fi
            ;;
        jest-related)
            build_jest_related_command
            npx --no-install jest $JEST_ARGS >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        package-test)
            sh -c "$TEST_COMMAND" >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        pytest)
            pytest >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        go-test)
            go test ./... >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        cargo-test)
            cargo test >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        *)
            return 0
            ;;
    esac
}

failing_test_matches_staged_module() {
    if [ -z "$FAILED_TEST_FILE" ]; then
        return 1
    fi

    for staged_file in $STAGED; do
        staged_name=$(basename "$staged_file")
        staged_name=${staged_name%.test.ts}
        staged_name=${staged_name%.test.tsx}
        staged_name=${staged_name%.test.js}
        staged_name=${staged_name%.test.jsx}
        staged_name=${staged_name%.test.mjs}
        staged_name=${staged_name%.test.cjs}
        staged_name=${staged_name%.spec.ts}
        staged_name=${staged_name%.spec.tsx}
        staged_name=${staged_name%.spec.js}
        staged_name=${staged_name%.spec.jsx}
        staged_name=${staged_name%.spec.mjs}
        staged_name=${staged_name%.spec.cjs}
        staged_name=${staged_name%.ts}
        staged_name=${staged_name%.tsx}
        staged_name=${staged_name%.js}
        staged_name=${staged_name%.jsx}
        staged_name=${staged_name%.mjs}
        staged_name=${staged_name%.cjs}
        staged_name=${staged_name%.py}
        staged_name=${staged_name%.go}
        staged_name=${staged_name%.rs}
        staged_name=${staged_name#test_}
        staged_name=${staged_name%_test}

        if [ -n "$staged_name" ] && echo "$FAILED_TEST_FILE" | grep -F "$staged_name" >/dev/null 2>&1; then
            return 0
        fi
    done

    return 1
}

build_related_test_failure_hint() {
    if grep -Eq 'AssertionError|expected .* to (be|equal|deeply equal|match|contain)' "$FILTERED_TEST_OUTPUT_FILE"; then
        if failing_test_matches_staged_module; then
            FAILED_TEST_HINT="This looks like a behavior change near the modified module. Check whether the affected test expectations need updating."
        else
            FAILED_TEST_HINT="This looks like an assertion mismatch. Check whether the implementation changed or the test expectation drifted."
        fi
    elif grep -Eq 'ReferenceError|TypeError|SyntaxError|Cannot find module|is not defined|Unhandled' "$FILTERED_TEST_OUTPUT_FILE"; then
        FAILED_TEST_HINT="This looks like a code regression or broken test setup. Check the implementation and stack trace."
    else
        FAILED_TEST_HINT="Inspect the first failing test and stack trace below."
    fi
}

print_related_test_summary() {
    echo "========================================"
    echo "TEST_FAILURE_SUMMARY"
    if [ -n "$TEST_STRATEGY" ]; then
        echo "TEST_STRATEGY: $TEST_STRATEGY"
    fi
    if [ -n "$TEST_COMMAND" ]; then
        echo "TEST_COMMAND: $TEST_COMMAND"
    fi
    if [ -n "$FAILED_TEST_FILE" ]; then
        echo "FAILED_TEST_FILE: $FAILED_TEST_FILE"
    fi
    if [ -n "$FAILED_TEST_HEADLINE" ]; then
        echo "FAILED_TEST: $FAILED_TEST_HEADLINE"
    fi
    if [ "$SUPPRESSED_TEST_WARNING_COUNT" -gt 0 ]; then
        echo "INFO: Suppressed $SUPPRESSED_TEST_WARNING_COUNT known MCP contract-tool warning line(s) from test output."
    fi
    echo "LIKELY_CAUSE: $FAILED_TEST_HINT"
    if [ -n "$FAILED_TEST_VERIFY_COMMAND" ]; then
        echo "VERIFY: $FAILED_TEST_VERIFY_COMMAND"
    fi
    if [ -n "$GENERAL_VERIFY_COMMAND" ] && [ "$GENERAL_VERIFY_COMMAND" != "$FAILED_TEST_VERIFY_COMMAND" ]; then
        echo "VERIFY: $GENERAL_VERIFY_COMMAND"
    fi
    echo "========================================"
}

run_related_tests() {
    TEST_OUTPUT_FILE=$(mktemp "${TMPDIR:-/tmp}/codemap-related-tests-XXXXXX")
    FILTERED_TEST_OUTPUT_FILE=$(mktemp "${TMPDIR:-/tmp}/codemap-related-tests-filtered-XXXXXX")

    run_test_precheck_command

    RELATED_TEST_EXIT=$?
    SUPPRESSED_TEST_WARNING_COUNT=$(grep -c '^Contract tool "' "$TEST_OUTPUT_FILE" 2>/dev/null || true)
    grep -v '^Contract tool "' "$TEST_OUTPUT_FILE" >"$FILTERED_TEST_OUTPUT_FILE" || true
    if [ ! -s "$FILTERED_TEST_OUTPUT_FILE" ]; then
        cp "$TEST_OUTPUT_FILE" "$FILTERED_TEST_OUTPUT_FILE"
    fi

    if [ "$RELATED_TEST_EXIT" -ne 0 ]; then
        cat "$FILTERED_TEST_OUTPUT_FILE"
        extract_failed_test_file
        FAILED_TEST_HEADLINE=$(grep -m 1 -E '^ FAIL |^FAIL |^FAILED |^--- FAIL:' "$FILTERED_TEST_OUTPUT_FILE" || true)
        build_failed_test_verify_command
        build_related_test_failure_hint
        print_related_test_summary
    fi

    cleanup_related_test_artifacts
    return "$RELATED_TEST_EXIT"
}

echo "Running pre-commit checks..."

# 1. 运行 staged source files 对应的测试预检（失败即阻断）
# 优先使用 runner-specific related tests；否则回退到项目级 test command
echo "Running tests for staged files..."

if build_test_precheck_plan; then
    STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E "$SOURCE_FILE_PATTERN" || true)
    if [ -z "$STAGED" ]; then
        echo "No $TEST_TARGET_KIND files staged, skipping tests"
    else
        STAGED_COUNT=$(printf '%s\n' "$STAGED" | wc -l | tr -d ' ')

        case "$TEST_STRATEGY" in
            vitest-related)
                if [ "$STAGED_COUNT" -le 3 ]; then
                    echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running related Vitest checks..."
                else
                    echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running related Vitest checks (single fork to reduce CPU load)..."
                fi
                ;;
            jest-related)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running related Jest checks..."
                ;;
            package-test)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running project test command fallback..."
                ;;
            pytest)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running pytest..."
                ;;
            go-test)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running go test ./..."
                ;;
            cargo-test)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running cargo test..."
                ;;
        esac

        run_related_tests
        if [ $? -ne 0 ]; then
            print_blocked_rule \
                "related-tests" \
                "$TEST_FAILURE_REASON"
            if [ -n "$TEST_STRATEGY" ]; then
                echo "TEST_STRATEGY: $TEST_STRATEGY"
            fi
            if [ -n "$TEST_COMMAND" ]; then
                echo "TEST_COMMAND: $TEST_COMMAND"
            fi
            if [ -n "$STAGED" ]; then
                echo "TRIGGERED_SOURCE_FILES:"
                printf '%s\n' "$STAGED"
            fi
            echo "FIX: Review the filtered failing test output and summary above."
            echo "FIX: Repair the code or tests, rerun one of the VERIFY commands, then retry the commit."
            exit 1
        fi
    fi
else
    echo "No supported staged-source test strategy detected, skipping tests"
fi

echo "Tests passed"

# 2. repo-local 规则校验（按 hard_gate.mode 决定 report-only / enforce）
RULE_CONFIG_PATH=".claude/rule-system.config.json"
RULE_HARD_GATE_MODE="report-only"
RULE_REPORT_ONLY_TIMEOUT_SECONDS="${RULE_REPORT_ONLY_TIMEOUT_SECONDS:-20}"

run_rule_validation_report_only() {
    python3 - <<'PY'
import os
import subprocess
import sys

timeout_value = os.environ.get("RULE_REPORT_ONLY_TIMEOUT_SECONDS", "20")

try:
    timeout_seconds = int(timeout_value)
except ValueError:
    timeout_seconds = 20

try:
    completed = subprocess.run(
        ["python3", "scripts/validate-rules.py", "code", "--report-only"],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        timeout=timeout_seconds,
    )
except subprocess.TimeoutExpired:
    sys.exit(124)

sys.exit(completed.returncode)
PY
}

if [ -f "$RULE_CONFIG_PATH" ]; then
    RULE_HARD_GATE_MODE=$(python3 - <<'PY'
import json
from pathlib import Path

config_path = Path(".claude/rule-system.config.json")

try:
    config = json.loads(config_path.read_text(encoding="utf-8"))
except Exception:
    print("report-only")
else:
    print(config.get("hard_gate", {}).get("mode", "report-only"))
PY
)
fi

echo "Running repo-local rule validation (mode: $RULE_HARD_GATE_MODE)..."
case "$RULE_HARD_GATE_MODE" in
    enforce)
        python3 scripts/validate-rules.py code
        VALIDATE_EXIT=$?
        case "$VALIDATE_EXIT" in
            0)
                echo "Rule validation passed"
                ;;
            1)
                print_blocked_rule \
                    "repo-local-rule-validation" \
                    "Repo-local rule validation found blocking P0 findings."
                echo "FIX: Run python3 scripts/validate-rules.py code to inspect the blocking findings."
                echo "FIX: Resolve the reported P0 issues, then retry the commit."
                exit 1
                ;;
            2)
                echo "WARNING: Rule validation reported warn-only P1 findings, continuing commit"
                ;;
            3)
                echo "WARNING: Rule validation reported notice-only P2 findings, continuing commit"
                ;;
            4)
                print_blocked_rule \
                    "repo-local-rule-validation-unavailable" \
                    "Repo-local rule validation could not run because required dependencies are unavailable."
                echo "FIX: Restore the rule validation dependencies, then rerun python3 scripts/validate-rules.py code."
                exit 1
                ;;
            *)
                print_blocked_rule \
                    "repo-local-rule-validation-unexpected" \
                    "Repo-local rule validation returned an unexpected exit code ($VALIDATE_EXIT)."
                echo "FIX: Run python3 scripts/validate-rules.py code manually and inspect the failure."
                exit 1
                ;;
        esac
        ;;
    report-only|*)
        if [ "$RULE_HARD_GATE_MODE" != "report-only" ]; then
            echo "WARNING: Unknown hard gate mode '$RULE_HARD_GATE_MODE', defaulting to report-only"
        fi
        run_rule_validation_report_only
        VALIDATE_EXIT=$?
        if [ "$VALIDATE_EXIT" -eq 124 ]; then
            echo "INFO: Rule validation report-only timed out after ${RULE_REPORT_ONLY_TIMEOUT_SECONDS}s (non-blocking), continuing commit"
        elif [ "$VALIDATE_EXIT" -ne 0 ]; then
            echo "INFO: Rule validation report-only command exited with $VALIDATE_EXIT (non-blocking), continuing commit"
        else
            echo "Rule validation report-only completed"
        fi
        ;;
esac

# 3. 检查 staged 文件数量（初始化 commit 除外）
# 规则: 单 commit 文件数量不能超过 10 个
# 例外: 如果包含文档类型文件，限制放宽到 20 个
MAX_FILES_PER_COMMIT=10
MAX_FILES_WITH_DOCS=20

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_FILE_COUNT=$(echo "$STAGED_FILES" | grep -c '^' || echo 0)

# 检查是否只包含以 . 开头的目录下的文件
# 如果是，则豁免数量和文件头检查
ONLY_DOT_DIRS=true
if [ -n "$STAGED_FILES" ]; then
    NON_DOT_FILES=$(echo "$STAGED_FILES" | grep -v '^\.' || true)
    if [ -n "$NON_DOT_FILES" ]; then
        ONLY_DOT_DIRS=false
    fi
fi

# 检查是否是初始化 commit（没有父提交）
IS_INITIAL_COMMIT=false
git rev-parse --verify HEAD >/dev/null 2>&1
if [ $? -ne 0 ]; then
    IS_INITIAL_COMMIT=true
fi

# 检查是否包含文档类型文件
# 文档类型: *.md, docs/* 目录下文件, README*, CHANGELOG*, LICENSE*
CONTAINS_DOC_FILES=false
if [ -n "$STAGED_FILES" ]; then
    DOC_FILES=$(echo "$STAGED_FILES" | grep -E '(\.md$|^docs/|^README|^CHANGELOG|^LICENSE)' || true)
    if [ -n "$DOC_FILES" ]; then
        CONTAINS_DOC_FILES=true
    fi
fi

# 根据是否包含文档类型文件设置限制
if [ "$CONTAINS_DOC_FILES" = "true" ]; then
    CURRENT_LIMIT=$MAX_FILES_WITH_DOCS
else
    CURRENT_LIMIT=$MAX_FILES_PER_COMMIT
fi

if [ "$ONLY_DOT_DIRS" = "true" ]; then
    echo "Note: Only dot-directory files staged, skipping count limit check"
elif [ "$STAGED_FILE_COUNT" -gt "$CURRENT_LIMIT" ] && [ "$IS_INITIAL_COMMIT" = "false" ]; then
    print_blocked_rule \
        "staged-file-limit" \
        "This non-initial commit stages $STAGED_FILE_COUNT files, which exceeds the allowed limit of $CURRENT_LIMIT."
    if [ "$CONTAINS_DOC_FILES" = "true" ]; then
        echo "FIX: This commit includes documentation files, so the higher limit is $MAX_FILES_WITH_DOCS files."
    else
        echo "FIX: Non-dot commits without documentation files must stay at or below $MAX_FILES_PER_COMMIT files."
    fi
    echo "FIX: Dot-directory-only commits are exempt from this rule."
    echo "FIX: Split the staged changes into smaller commits, then retry."
    echo "STAGED_FILES:"
    git diff --cached --name-only --diff-filter=ACM
    exit 1
fi

# 4. 检查文件头注释（只检查 staged 的 TS 源文件，豁免 . 开头目录）
echo "Checking file headers..."
if [ "$ONLY_DOT_DIRS" = "true" ]; then
    echo "Note: Only dot-directory files staged, skipping header check"
    STAGED_TS_FILES=""
else
    STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' | grep -v '\.test\.ts$' | grep -v '\.d\.ts$')
fi

if [ -n "$STAGED_TS_FILES" ]; then
    MISSING_HEADERS=0

    for file in $STAGED_TS_FILES; do
        if [ ! -f "$file" ]; then
            continue
        fi

        HEAD_CONTENT=$(head -10 "$file")

        if ! echo "$HEAD_CONTENT" | grep -q '\[META\]'; then
            echo "ERROR: $file missing [META] comment"
            MISSING_HEADERS=$((MISSING_HEADERS + 1))
        fi

        if ! echo "$HEAD_CONTENT" | grep -q '\[WHY\]'; then
            echo "ERROR: $file missing [WHY] comment"
            MISSING_HEADERS=$((MISSING_HEADERS + 1))
        fi
    done

    if [ $MISSING_HEADERS -gt 0 ]; then
        print_blocked_rule \
            "source-file-headers" \
            "Non-test, non-.d.ts TypeScript source files staged outside dot-directories must include [META] and [WHY] in the first 10 lines."
        echo "FIX: Add these header lines at the top of each listed file:"
        echo "FIX: // [META] since:YYYY-MM | owner:team | stable:false"
        echo "FIX: // [WHY] Explain why this file exists"
        exit 1
    fi
fi

echo "File headers passed"

# 5a. 轻量真实验证检查（warn-only）
# 如果新增/修改了测试文件，检查是否包含真实调用模式
echo "Checking for real-world test patterns..."
STAGED_TEST_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.test\.ts$' || true)
if [ -n "$STAGED_TEST_FILES" ]; then
    MISSING_REAL_PATTERN=0
    for file in $STAGED_TEST_FILES; do
        if [ ! -f "$file" ]; then
            continue
        fi
        # 检查是否包含真实调用模式
        # 注意：StdioServerTransport + PassThrough 是真实 MCP transport 测试模式
        if ! grep -qE '(spawn|execSync|execFileSync|mktemp|StdioServerTransport|PassThrough|createServer|listen)' "$file"; then
            echo "WARNING: $file does not appear to contain real-world invocation patterns (spawn, execSync, mktemp, StdioServerTransport, PassThrough, etc.)"
            MISSING_REAL_PATTERN=$((MISSING_REAL_PATTERN + 1))
        fi
    done
    if [ $MISSING_REAL_PATTERN -gt 0 ]; then
        echo ""
        echo "Consider adding integration/E2E tests with real subprocess/transport calls."
        echo "See AGENTS.md Section 8.1 for the real-world validation threshold."
        echo "This is a warning only; commit will proceed."
        echo ""
    fi
fi

# 5. 检查文档与 CLI 护栏（仅在相关文件变更时阻断）
DOC_GUARDRAIL_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(README\.md|package\.json|docs/|src/cli/index\.ts|vitest\.config\.ts|vitest\.benchmark\.config\.ts|\.github/workflows/ci-gateway\.yml)$' || true)

if [ -n "$DOC_GUARDRAIL_FILES" ]; then
    echo "Checking documentation guardrails..."
    npm run docs:check
    if [ $? -ne 0 ]; then
        print_blocked_rule \
            "docs-guardrail" \
            "Documentation guardrails run whenever staged files touch README/package metadata, docs, CLI entrypoints, vitest config, or the CI gateway workflow."
        echo "TRIGGERED_BY:"
        printf '%s\n' "$DOC_GUARDRAIL_FILES"
        echo "FIX: Run npm run docs:check and resolve the reported documentation drift."
        echo "FIX: Retry the commit after docs:check passes."
        exit 1
    fi
fi

echo "Documentation guardrails passed"

# 6. 生成 AI 饲料（警告级，不阻断）
echo "Generating AI feed..."
npx mycodemap generate --quiet >/dev/null 2>&1 &
if [ $? -ne 0 ]; then
    echo "WARNING: Failed to start AI feed generation"
fi

echo "Pre-commit checks passed"
exit 0
