prepare_attempt_context() {
    CHECK_RESULTS_FILE=$(mktemp "${TMPDIR:-/tmp}/codemap-precheck-results-XXXXXX")
    ATTEMPT_TIMESTAMP=$(python3 - <<'PY'
from datetime import datetime, timezone
print(datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%S%fZ'))
PY
)
    ATTEMPT_ID="${CODEMAP_ATTEMPT_ID:-precommit-${ATTEMPT_TIMESTAMP}-$$}"
    ATTEMPT_LOG_RELATIVE_PATH=".mycodemap/logs/pre-commit/${ATTEMPT_ID}.json"
    ATTEMPT_LOG_ABSOLUTE_PATH="$(pwd)/$ATTEMPT_LOG_RELATIVE_PATH"
