resolve_rule_definition_line() {
    marker="$1"
    if [ ! -f "$HOOK_SOURCE" ]; then
        echo ""
        return 0
    fi

    grep -nF "$marker" "$HOOK_SOURCE" | head -n 1 | cut -d: -f1
}

build_rule_metadata_json() {
    rule_id="$1"
    definition_marker=""
    doc_ref=""
    override_process=""

    case "$rule_id" in
        staged-file-limit)
            definition_marker='MAX_FILES_PER_COMMIT=10'
            override_process='文件数限制不可覆盖；dot-directory-only commits 豁免；若认为必须保持单一原子提交，请请求人工审查。'
            ;;
        source-file-headers)
            definition_marker='Checking file headers...'
            override_process='为缺失文件补齐 [META]/[WHY] 头注释后重试。'
            ;;
        docs-guardrail)
            definition_marker='DOC_GUARDRAIL_FILES='
            override_process='先修复 docs:check 报告的问题；该规则不支持跳过。'
            ;;
        related-tests)
            definition_marker='build_test_precheck_plan() {'
            doc_ref='docs/rules/testing.md#测试框架'
            override_process='修复代码或测试，并使用 VERIFY 命令重跑；不要通过忽略 hook 绕过。'
            ;;
        repo-local-rule-validation|repo-local-rule-validation-unavailable|repo-local-rule-validation-unexpected)
            definition_marker='RULE_CONFIG_PATH=".claude/rule-system.config.json"'
            override_process='按配置决定 enforce/report-only；若为 enforce，必须修复阻断问题后重试。'
            ;;
        *)
            definition_marker='print_blocked_rule() {'
            override_process='按照该规则提示修复后重试。'
            ;;
    esac

    RULE_ID_FOR_JSON="$rule_id" \
    RULE_LINE_FOR_JSON="$(resolve_rule_definition_line "$definition_marker")" \
    RULE_DOC_REF_FOR_JSON="$doc_ref" \
    RULE_OVERRIDE_FOR_JSON="$override_process" \
    python3 - <<'PY'
import json
import os

rule_id = os.environ.get('RULE_ID_FOR_JSON', '')
line = os.environ.get('RULE_LINE_FOR_JSON', '').strip()
doc_ref = os.environ.get('RULE_DOC_REF_FOR_JSON', '').strip()
override_process = os.environ.get('RULE_OVERRIDE_FOR_JSON', '').strip()

definition = '.mycodemap/hooks/pre-commit'
if line:
    definition = f'{definition}:{line}'

payload = {
    'id': rule_id,
    'defined_at': definition,
    'doc_ref': doc_ref or None,
    'override_process': override_process or None,
}
print(json.dumps(payload, separators=(',', ':')))
PY
}

render_protocol_json() {
    final_status="$1"
    next_action="$2"
    blocked_rule="$3"
    blocked_reason="$4"
    resolution_json="${5:-null}"
    rule_metadata_json="${6:-null}"

    FINAL_STATUS="$final_status" \
    NEXT_ACTION="$next_action" \
    BLOCKED_RULE="$blocked_rule" \
    BLOCKED_REASON="$blocked_reason" \
    BLOCK_RESOLUTION_JSON="$resolution_json" \
    RULE_METADATA_JSON="$rule_metadata_json" \
    RULE_HARD_GATE_MODE="$RULE_HARD_GATE_MODE" \
    HOOK_SOURCE="$HOOK_SOURCE" \
    ATTEMPT_ID="$ATTEMPT_ID" \
    ATTEMPT_LOG_RELATIVE_PATH="$ATTEMPT_LOG_RELATIVE_PATH" \
    AGENT_CONTEXT_RAW="$AGENT_CONTEXT_RAW" \
    PARENT_COMMIT="$PARENT_COMMIT" \
    PROTOCOL_ONLY_VALUE="$PROTOCOL_ONLY" \
    PROTOCOL_OUTPUT_MODE_VALUE="$PROTOCOL_OUTPUT_MODE" \
    STAGED_FILES_RAW="$STAGED_FILES" \
    STAGED_FILE_COUNT_VALUE="$STAGED_FILE_COUNT" \
    NON_DOT_FILES_RAW="$NON_DOT_FILES" \
    DOC_FILES_RAW="$DOC_FILES" \
    CURRENT_LIMIT_VALUE="$CURRENT_LIMIT" \
    ONLY_DOT_DIRS_VALUE="$ONLY_DOT_DIRS" \
    IS_INITIAL_COMMIT_VALUE="$IS_INITIAL_COMMIT" \
    CONTAINS_DOC_FILES_VALUE="$CONTAINS_DOC_FILES" \
    python3 - "$CHECK_RESULTS_FILE" <<'PY'
import json
import os
import sys
from pathlib import Path

check_file = Path(sys.argv[1])

def load_jsonish(raw: str):
    candidates = [raw]
    trimmed = raw.strip()
    if trimmed != raw:
        candidates.append(trimmed)
    if trimmed.startswith("'") and trimmed.endswith("'") and len(trimmed) >= 2:
        candidates.append(trimmed[1:-1])
    while trimmed.count('{') < trimmed.count('}') and trimmed.endswith('}'):
        trimmed = trimmed[:-1]
        candidates.append(trimmed)

    seen = set()
    for candidate in candidates:
        if candidate in seen:
            continue
        seen.add(candidate)
        try:
            value = json.loads(candidate)
            while isinstance(value, str):
                value = json.loads(value)
            return value
        except Exception:
            continue
    raise ValueError(raw)

records = []
if check_file.exists():
    for line in check_file.read_text(encoding='utf-8').splitlines():
        line = line.strip()
        if line:
            record = json.loads(line)
            details = record.get('details')
            if isinstance(details, dict) and 'raw' in details:
                try:
                    normalized = load_jsonish(details['raw'])
                    record['details'] = normalized
                except Exception:
                    pass
            records.append(record)

rule_mode = os.environ.get('RULE_HARD_GATE_MODE', 'report-only')
catalog = [
    {'name': 'staged-file-limit', 'order': 0, 'complexity': 'O(1)', 'blocking': True},
    {'name': 'source-file-headers', 'order': 1, 'complexity': 'O(staged TypeScript files)', 'blocking': True},
    {'name': 'docs-guardrail', 'order': 2, 'complexity': 'O(1)+docs:check', 'blocking': True},
    {'name': 'related-tests', 'order': 3, 'complexity': 'O(changed source files + selected tests)', 'blocking': True},
    {'name': 'repo-local-rule-validation', 'order': 4, 'complexity': 'O(rule validation)', 'blocking': rule_mode == 'enforce'},
    {'name': 'real-world-test-patterns', 'order': 5, 'complexity': 'O(staged test files)', 'blocking': False},
    {'name': 'ai-feed-generation', 'order': 6, 'complexity': 'O(1)+background', 'blocking': False},
]
record_map = {record['name']: record for record in records}
blocked_rule = os.environ.get('BLOCKED_RULE', '').strip()
blocked_order = None
for item in catalog:
    if item['name'] == blocked_rule or (blocked_rule.startswith('repo-local-rule-validation') and item['name'] == 'repo-local-rule-validation'):
        blocked_order = item['order']
        break
if blocked_order is not None:
    for item in catalog:
        if item['name'] not in record_map and item['order'] > blocked_order:
            record_map[item['name']] = {
                'name': item['name'],
                'status': 'skipped',
                'duration_ms': 0,
                'details': {},
                'skip_reason': f'blocked-by-{blocked_rule}',
            }

checks = []
for item in catalog:
    record = record_map.get(item['name'])
    if record is None:
        record = {
            'name': item['name'],
            'status': 'skipped',
            'duration_ms': 0,
            'details': {},
            'skip_reason': 'not-run',
        }
    merged = dict(item)
    merged.update(record)
    if 'blocking_override' in merged:
        merged['blocking'] = merged.pop('blocking_override')
    details = merged.get('details')
    if isinstance(details, dict) and 'raw' in details:
        try:
            normalized = load_jsonish(details['raw'])
            merged['details'] = normalized
        except Exception:
            pass
    checks.append(merged)

agent_context_raw = os.environ.get('AGENT_CONTEXT_RAW', '').strip()
agent_context = None
agent_context_error = None
if agent_context_raw:
    try:
        agent_context = json.loads(agent_context_raw)
    except Exception as exc:
        agent_context_error = str(exc)
        agent_context = {'raw': agent_context_raw}

resolution_raw = os.environ.get('BLOCK_RESOLUTION_JSON', 'null')
rule_metadata_raw = os.environ.get('RULE_METADATA_JSON', 'null')
try:
    resolution = json.loads(resolution_raw)
except Exception:
    resolution = {'raw': resolution_raw}
try:
    rule_metadata = json.loads(rule_metadata_raw)
except Exception:
    rule_metadata = {'raw': rule_metadata_raw}

staged_files = [line for line in os.environ.get('STAGED_FILES_RAW', '').splitlines() if line.strip()]
non_dot_files = [line for line in os.environ.get('NON_DOT_FILES_RAW', '').splitlines() if line.strip()]
doc_files = [line for line in os.environ.get('DOC_FILES_RAW', '').splitlines() if line.strip()]

payload = {
    'schema': 'codemap.precommit.v1',
    'hook_source': os.environ.get('HOOK_SOURCE', '.mycodemap/hooks/pre-commit'),
    'output': {
        'protocol_only': os.environ.get('PROTOCOL_ONLY_VALUE', '0') == '1',
        'mode': os.environ.get('PROTOCOL_OUTPUT_MODE_VALUE', 'human-and-protocol'),
    },
    'attempt': {
        'attempt_id': os.environ.get('ATTEMPT_ID', ''),
        'log_path': os.environ.get('ATTEMPT_LOG_RELATIVE_PATH', ''),
        'context_env': 'CODEMAP_AGENT_CONTEXT',
        'input_context': agent_context,
        'input_context_parse_error': agent_context_error,
        'parent_commit': os.environ.get('PARENT_COMMIT', '') or None,
    },
    'commit_allowed': os.environ.get('FINAL_STATUS', 'allowed') == 'allowed',
    'next_action': os.environ.get('NEXT_ACTION', 'commit'),
    'repo': {
        'staged_files': staged_files,
        'staged_count': int(os.environ.get('STAGED_FILE_COUNT_VALUE', '0') or '0'),
        'non_dot_files': non_dot_files,
        'doc_files': doc_files,
        'current_limit': int(os.environ.get('CURRENT_LIMIT_VALUE', '0') or '0'),
        'only_dot_dirs': os.environ.get('ONLY_DOT_DIRS_VALUE', 'false') == 'true',
        'is_initial_commit': os.environ.get('IS_INITIAL_COMMIT_VALUE', 'false') == 'true',
        'contains_doc_files': os.environ.get('CONTAINS_DOC_FILES_VALUE', 'false') == 'true',
    },
    'checks': checks,
}

if blocked_rule:
    payload['block'] = {
        'rule_id': blocked_rule,
        'why': os.environ.get('BLOCKED_REASON', ''),
        'rule': rule_metadata,
        'resolution': resolution,
    }

print(json.dumps(payload, separators=(',', ':')))
PY
}

emit_protocol_line() {
    final_status="$1"
    next_action="$2"
    blocked_rule="$3"
    blocked_reason="$4"
    resolution_json="${5:-null}"
    rule_metadata_json="${6:-null}"

    PROTOCOL_JSON=$(render_protocol_json "$final_status" "$next_action" "$blocked_rule" "$blocked_reason" "$resolution_json" "$rule_metadata_json")
    if [ -n "$ATTEMPT_LOG_ABSOLUTE_PATH" ]; then
        printf '%s\n' "$PROTOCOL_JSON" >"$ATTEMPT_LOG_ABSOLUTE_PATH" 2>/dev/null || true
    fi
    if [ -n "$ATTEMPT_LOG_RELATIVE_PATH" ]; then
        printf 'CODEMAP_PRECHECK_LOG_PATH:%s\n' "$ATTEMPT_LOG_RELATIVE_PATH" >&3
    fi
    printf 'CODEMAP_PRECHECK_PROTOCOL:%s\n' "$PROTOCOL_JSON" >&3
}

print_blocked_rule() {
    rule_id="$1"
    reason="$2"

    echo 'ERROR: Commit precheck blocked the commit.'
    echo "RULE_ID: $rule_id"
    echo "HOOK_SOURCE: $HOOK_SOURCE"
    echo "WHY: $reason"
}

read_package_json_metadata() {
    if [ ! -f 'package.json' ]; then
        return 1
    fi

    PACKAGE_JSON_METADATA=$(python3 - <<'PY'
import json
from pathlib import Path

try:
    pkg = json.loads(Path('package.json').read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(1)

scripts = pkg.get('scripts') or {}
package_manager = str(pkg.get('packageManager') or '').strip()
test_script = str(scripts.get('test') or '').strip()

print(package_manager)
print(test_script)
PY
) || return 1

    PACKAGE_MANAGER_HINT=$(printf '%s\n' "$PACKAGE_JSON_METADATA" | sed -n '1p')
    TEST_SCRIPT=$(printf '%s\n' "$PACKAGE_JSON_METADATA" | sed -n '2p')
    return 0
}

resolve_package_manager() {
    PACKAGE_MANAGER=''
    PACKAGE_MANAGER_HINT=''
    TEST_SCRIPT=''

    read_package_json_metadata || true

    case "$PACKAGE_MANAGER_HINT" in
        pnpm@*|pnpm)
            PACKAGE_MANAGER='pnpm'
            ;;
        yarn@*|yarn)
            PACKAGE_MANAGER='yarn'
            ;;
        bun@*|bun)
            PACKAGE_MANAGER='bun'
            ;;
        npm@*|npm)
            PACKAGE_MANAGER='npm'
            ;;
    esac

    if [ -z "$PACKAGE_MANAGER" ]; then
        if [ -f 'pnpm-lock.yaml' ]; then
            PACKAGE_MANAGER='pnpm'
        elif [ -f 'yarn.lock' ]; then
            PACKAGE_MANAGER='yarn'
        elif [ -f 'bun.lockb' ] || [ -f 'bun.lock' ]; then
            PACKAGE_MANAGER='bun'
        elif [ -f 'package-lock.json' ] || [ -f 'package.json' ]; then
            PACKAGE_MANAGER='npm'
        fi
    fi
}

build_package_test_command() {
    case "$PACKAGE_MANAGER" in
        pnpm)
            PACKAGE_TEST_COMMAND='pnpm test'
            ;;
        yarn)
            PACKAGE_TEST_COMMAND='yarn test'
            ;;
        bun)
            PACKAGE_TEST_COMMAND='bun test'
            ;;
        npm|*)
            PACKAGE_TEST_COMMAND='npm test'
            ;;
    esac
}

ensure_vitest_entry() {
    VITEST_ENTRY=''

    if [ -f 'node_modules/vitest/vitest.mjs' ]; then
        VITEST_ENTRY='node_modules/vitest/vitest.mjs'
        return 0
    fi

    if [ -d 'node_modules' ] && [ ! -e 'node_modules/vitest' ]; then
        VITEST_PACKAGE_DIR=$(find node_modules -type d -path '*/.pnpm/*/node_modules/vitest' | head -n 1)
        if [ -n "$VITEST_PACKAGE_DIR" ]; then
            ln -sfn "${VITEST_PACKAGE_DIR#node_modules/}" node_modules/vitest
        fi
    fi

    if [ -f 'node_modules/vitest/vitest.mjs' ]; then
        VITEST_ENTRY='node_modules/vitest/vitest.mjs'
        return 0
    fi

    if [ -d 'node_modules' ]; then
        VITEST_ENTRY=$(find node_modules -type f -path '*/.pnpm/*/node_modules/vitest/vitest.mjs' | head -n 1)
        if [ -z "$VITEST_ENTRY" ]; then
            VITEST_ENTRY=$(find node_modules -type f -path '*/.vitest-*/vitest.mjs' | head -n 1)
        fi
    fi

    if [ -n "$VITEST_ENTRY" ]; then
        return 0
    fi

    return 1
}

build_vitest_related_command() {
    GENERAL_VERIFY_COMMAND='npx vitest related'
    for staged_file in $STAGED; do
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND $staged_file"
    done
    GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --watch=false --bail=1"
    if [ "$STAGED_COUNT" -gt 3 ]; then
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --pool=forks --poolOptions.forks.singleFork"
    fi
    TEST_COMMAND="$GENERAL_VERIFY_COMMAND"
    VITEST_ARGS=${GENERAL_VERIFY_COMMAND#npx vitest }
}

build_jest_related_command() {
    GENERAL_VERIFY_COMMAND='npx jest --findRelatedTests'
    for staged_file in $STAGED; do
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND $staged_file"
    done
    GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --bail"
    if [ "$STAGED_COUNT" -gt 3 ]; then
        GENERAL_VERIFY_COMMAND="$GENERAL_VERIFY_COMMAND --runInBand"
    fi
    TEST_COMMAND="$GENERAL_VERIFY_COMMAND"
    JEST_ARGS=${GENERAL_VERIFY_COMMAND#npx jest }
}

build_test_precheck_plan() {
    TEST_COMMAND=''
    TEST_STRATEGY=''
    TEST_FAILURE_REASON=''
    TEST_TARGET_KIND=''
    SOURCE_FILE_PATTERN=''
    GENERAL_VERIFY_COMMAND=''
    FAILED_TEST_VERIFY_COMMAND=''
    PACKAGE_TEST_COMMAND=''

    resolve_package_manager

    SOURCE_FILE_PATTERN='\.[cm]?[jt]sx?$'
    TEST_TARGET_KIND='JS/TS source'

    if [ -f 'package.json' ]; then
        if echo "$TEST_SCRIPT" | grep -Eq '^vitest([[:space:]].*)?$'; then
            TEST_STRATEGY='vitest-related'
            TEST_FAILURE_REASON='Related Vitest checks for the staged source files failed.'
            return 0
        fi

        if echo "$TEST_SCRIPT" | grep -Eq '^jest([[:space:]].*)?$'; then
            TEST_STRATEGY='jest-related'
            TEST_FAILURE_REASON='Related Jest checks for the staged source files failed.'
            return 0
        fi

        if [ -z "$TEST_SCRIPT" ] && ensure_vitest_entry; then
            TEST_STRATEGY='vitest-related'
            TEST_FAILURE_REASON='Related Vitest checks for the staged source files failed.'
            return 0
        fi

        if [ -n "$TEST_SCRIPT" ]; then
            build_package_test_command
            TEST_STRATEGY='package-test'
            TEST_COMMAND="$PACKAGE_TEST_COMMAND"
            GENERAL_VERIFY_COMMAND="$PACKAGE_TEST_COMMAND"
            TEST_FAILURE_REASON='The project test command for the staged source files failed.'
            return 0
        fi
    fi

    if ensure_vitest_entry; then
        TEST_STRATEGY='vitest-related'
        TEST_FAILURE_REASON='Related Vitest checks for the staged source files failed.'
        return 0
    fi

    if [ -f 'pyproject.toml' ]; then
        TEST_STRATEGY='pytest'
        TEST_TARGET_KIND='Python source'
        SOURCE_FILE_PATTERN='\.py$'
        TEST_COMMAND='pytest'
        GENERAL_VERIFY_COMMAND='pytest'
        TEST_FAILURE_REASON='Pytest failed for the staged source files.'
        return 0
    fi

    if [ -f 'go.mod' ]; then
        TEST_STRATEGY='go-test'
        TEST_TARGET_KIND='Go source'
        SOURCE_FILE_PATTERN='\.go$'
        TEST_COMMAND='go test ./...'
        GENERAL_VERIFY_COMMAND='go test ./...'
        TEST_FAILURE_REASON='Go tests failed for the staged source files.'
        return 0
    fi

    if [ -f 'Cargo.toml' ]; then
        TEST_STRATEGY='cargo-test'
        TEST_TARGET_KIND='Rust source'
        SOURCE_FILE_PATTERN='\.rs$'
        TEST_COMMAND='cargo test'
        GENERAL_VERIFY_COMMAND='cargo test'
        TEST_FAILURE_REASON='Cargo tests failed for the staged source files.'
        return 0
    fi

    return 1
}

extract_failed_test_file() {
    FAILED_TEST_FILE=''

    case "$TEST_STRATEGY" in
        pytest)
            FAILED_TEST_FILE=$(grep -Eo '([A-Za-z0-9_./-]+/)?(test_[A-Za-z0-9_./-]+\.py|[A-Za-z0-9_./-]+_test\.py)' "$FILTERED_TEST_OUTPUT_FILE" | head -n 1)
            ;;
        go-test)
            FAILED_TEST_FILE=$(grep -Eo '[A-Za-z0-9_./-]+_test\.go' "$FILTERED_TEST_OUTPUT_FILE" | head -n 1)
            ;;
        cargo-test)
            FAILED_TEST_FILE=''
            ;;
        *)
            FAILED_TEST_FILE=$(grep -Eo '[A-Za-z0-9_./-]+\.(test|spec)\.[cm]?[jt]sx?' "$FILTERED_TEST_OUTPUT_FILE" | head -n 1)
            ;;
    esac
}

build_failed_test_verify_command() {
    FAILED_TEST_VERIFY_COMMAND=''

    if [ -z "$FAILED_TEST_FILE" ]; then
        return 0
    fi

    case "$TEST_STRATEGY" in
        vitest-related)
            FAILED_TEST_VERIFY_COMMAND="npx vitest run $FAILED_TEST_FILE"
            ;;
        jest-related)
            FAILED_TEST_VERIFY_COMMAND="npx jest $FAILED_TEST_FILE --runInBand"
            ;;
        pytest)
            FAILED_TEST_VERIFY_COMMAND="pytest $FAILED_TEST_FILE"
            ;;
    esac
}

run_test_precheck_command() {
    case "$TEST_STRATEGY" in
        vitest-related)
            build_vitest_related_command
            if ensure_vitest_entry; then
                node "$VITEST_ENTRY" $VITEST_ARGS >"$TEST_OUTPUT_FILE" 2>&1
            else
                npx --yes vitest $VITEST_ARGS >"$TEST_OUTPUT_FILE" 2>&1
            fi
            ;;
        jest-related)
            build_jest_related_command
            npx --no-install jest $JEST_ARGS >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        package-test)
            sh -c "$TEST_COMMAND" >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        pytest)
            pytest >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        go-test)
            go test ./... >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        cargo-test)
            cargo test >"$TEST_OUTPUT_FILE" 2>&1
            ;;
        *)
            return 0
            ;;
    esac
}

failing_test_matches_staged_module() {
    if [ -z "$FAILED_TEST_FILE" ]; then
        return 1
    fi

    for staged_file in $STAGED; do
        staged_name=$(basename "$staged_file")
        staged_name=${staged_name%.test.ts}
        staged_name=${staged_name%.test.tsx}
        staged_name=${staged_name%.test.js}
        staged_name=${staged_name%.test.jsx}
        staged_name=${staged_name%.test.mjs}
        staged_name=${staged_name%.test.cjs}
        staged_name=${staged_name%.spec.ts}
        staged_name=${staged_name%.spec.tsx}
        staged_name=${staged_name%.spec.js}
        staged_name=${staged_name%.spec.jsx}
        staged_name=${staged_name%.spec.mjs}
        staged_name=${staged_name%.spec.cjs}
        staged_name=${staged_name%.ts}
        staged_name=${staged_name%.tsx}
        staged_name=${staged_name%.js}
        staged_name=${staged_name%.jsx}
        staged_name=${staged_name%.mjs}
        staged_name=${staged_name%.cjs}
        staged_name=${staged_name%.py}
        staged_name=${staged_name%.go}
        staged_name=${staged_name%.rs}
        staged_name=${staged_name#test_}
        staged_name=${staged_name%_test}

        if [ -n "$staged_name" ] && echo "$FAILED_TEST_FILE" | grep -F "$staged_name" >/dev/null 2>&1; then
            return 0
        fi
    done

    return 1
}

build_related_test_failure_hint() {
    if grep -Eq 'AssertionError|expected .* to (be|equal|deeply equal|match|contain)' "$FILTERED_TEST_OUTPUT_FILE"; then
        if failing_test_matches_staged_module; then
            FAILED_TEST_HINT='This looks like a behavior change near the modified module. Check whether the affected test expectations need updating.'
        else
            FAILED_TEST_HINT='This looks like an assertion mismatch. Check whether the implementation changed or the test expectation drifted.'
        fi
    elif grep -Eq 'ReferenceError|TypeError|SyntaxError|Cannot find module|is not defined|Unhandled' "$FILTERED_TEST_OUTPUT_FILE"; then
        FAILED_TEST_HINT='This looks like a code regression or broken test setup. Check the implementation and stack trace.'
    else
        FAILED_TEST_HINT='Inspect the first failing test and stack trace below.'
    fi
}

print_related_test_summary() {
    echo '========================================'
    echo 'TEST_FAILURE_SUMMARY'
    if [ -n "$TEST_STRATEGY" ]; then
        echo "TEST_STRATEGY: $TEST_STRATEGY"
    fi
    if [ -n "$TEST_COMMAND" ]; then
        echo "TEST_COMMAND: $TEST_COMMAND"
    fi
    if [ -n "$FAILED_TEST_FILE" ]; then
        echo "FAILED_TEST_FILE: $FAILED_TEST_FILE"
    fi
    if [ -n "$FAILED_TEST_HEADLINE" ]; then
        echo "FAILED_TEST: $FAILED_TEST_HEADLINE"
    fi
    if [ "$SUPPRESSED_TEST_WARNING_COUNT" -gt 0 ]; then
        echo "INFO: Suppressed $SUPPRESSED_TEST_WARNING_COUNT known MCP contract-tool warning line(s) from test output."
    fi
    echo "LIKELY_CAUSE: $FAILED_TEST_HINT"
    if [ -n "$FAILED_TEST_VERIFY_COMMAND" ]; then
        echo "VERIFY: $FAILED_TEST_VERIFY_COMMAND"
    fi
    if [ -n "$GENERAL_VERIFY_COMMAND" ] && [ "$GENERAL_VERIFY_COMMAND" != "$FAILED_TEST_VERIFY_COMMAND" ]; then
