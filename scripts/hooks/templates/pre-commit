load_rule_hard_gate_mode

echo 'Running pre-commit checks...'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_FILE_COUNT=$(count_non_empty_lines "$STAGED_FILES")
NON_DOT_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -v '^\.' || true)
if [ -n "$NON_DOT_FILES" ]; then
    ONLY_DOT_DIRS=false
fi
if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    IS_INITIAL_COMMIT=true
fi
DOC_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '(\.md$|^docs/|^README|^CHANGELOG|^LICENSE)' || true)
if [ -n "$DOC_FILES" ]; then
    CONTAINS_DOC_FILES=true
fi
if [ "$CONTAINS_DOC_FILES" = 'true' ]; then
    CURRENT_LIMIT=$MAX_FILES_WITH_DOCS
else
    CURRENT_LIMIT=$MAX_FILES_PER_COMMIT
fi

# 1. staged-file-limit: O(1) 失败前置
limit_start_ms=$(now_ms)
if [ "$ONLY_DOT_DIRS" = 'true' ]; then
    echo 'Note: Only dot-directory files staged, skipping count limit check'
    limit_end_ms=$(now_ms)
    record_staged_file_limit_check 'not_applicable' "$((limit_end_ms - limit_start_ms))" 'dot-directory-exemption'
elif [ "$STAGED_FILE_COUNT" -gt "$CURRENT_LIMIT" ] && [ "$IS_INITIAL_COMMIT" = 'false' ]; then
    limit_end_ms=$(now_ms)
    record_staged_file_limit_check 'failed' "$((limit_end_ms - limit_start_ms))"
    print_blocked_rule 'staged-file-limit' "This non-initial commit stages $STAGED_FILE_COUNT files, which exceeds the allowed limit of $CURRENT_LIMIT."
    if [ "$CONTAINS_DOC_FILES" = 'true' ]; then
        echo "FIX: This commit includes documentation files, so the higher limit is $MAX_FILES_WITH_DOCS files."
    else
        echo "FIX: Non-dot commits without documentation files must stay at or below $MAX_FILES_PER_COMMIT files."
    fi
    echo 'FIX: Dot-directory-only commits are exempt from this rule.'
    echo 'FIX: Split the staged changes into smaller commits, then retry.'
    echo 'STAGED_FILES:'
    printf '%s\n' "$STAGED_FILES"
    resolution_json=$(build_staged_file_limit_resolution_json)
    rule_metadata_json=$(build_rule_metadata_json 'staged-file-limit')
    emit_protocol_line 'blocked' 'split_commit' 'staged-file-limit' "This non-initial commit stages $STAGED_FILE_COUNT files, which exceeds the allowed limit of $CURRENT_LIMIT." "$resolution_json" "$rule_metadata_json"
    exit 1
else
    limit_end_ms=$(now_ms)
    record_staged_file_limit_check 'passed' "$((limit_end_ms - limit_start_ms))"
fi

# 2. source-file-headers: 便宜阻断前置
header_start_ms=$(now_ms)
echo 'Checking file headers...'
if [ "$ONLY_DOT_DIRS" = 'true' ]; then
    echo 'Note: Only dot-directory files staged, skipping header check'
    STAGED_TS_FILES=''
    header_end_ms=$(now_ms)
    record_source_headers_check 'not_applicable' "$((header_end_ms - header_start_ms))" 'dot-directory-exemption'
else
    STAGED_TS_FILES=$(printf '%s\n' "$STAGED_FILES" | grep '\.ts$' | grep -v '\.test\.ts$' | grep -v '\.d\.ts$' || true)
    if [ -z "$STAGED_TS_FILES" ]; then
        echo 'No TypeScript source files staged, skipping header check'
        header_end_ms=$(now_ms)
        record_source_headers_check 'not_applicable' "$((header_end_ms - header_start_ms))" 'no-typescript-source-files'
    else
        MISSING_HEADERS=0
        MISSING_HEADER_FILES=''
        for file in $STAGED_TS_FILES; do
            if [ ! -f "$file" ]; then
                continue
            fi

            HEAD_CONTENT=$(head -10 "$file")
            missing_for_file=false
            if ! echo "$HEAD_CONTENT" | grep -q '\[META\]'; then
                echo "ERROR: $file missing [META] comment"
                MISSING_HEADERS=$((MISSING_HEADERS + 1))
                missing_for_file=true
            fi
            if ! echo "$HEAD_CONTENT" | grep -q '\[WHY\]'; then
                echo "ERROR: $file missing [WHY] comment"
                MISSING_HEADERS=$((MISSING_HEADERS + 1))
                missing_for_file=true
            fi
            if [ "$missing_for_file" = 'true' ]; then
                MISSING_HEADER_FILES=$(printf '%s\n%s' "$MISSING_HEADER_FILES" "$file" | sed '/^[[:space:]]*$/d')
            fi
        done

        if [ "$MISSING_HEADERS" -gt 0 ]; then
            header_end_ms=$(now_ms)
            record_source_headers_check 'failed' "$((header_end_ms - header_start_ms))"
            print_blocked_rule 'source-file-headers' 'Non-test, non-.d.ts TypeScript source files staged outside dot-directories must include [META] and [WHY] in the first 10 lines.'
            echo 'FIX: Add these header lines at the top of each listed file:'
            echo 'FIX: // [META] since:YYYY-MM | owner:team | stable:false'
            echo 'FIX: // [WHY] Explain why this file exists'
            resolution_json=$(build_header_resolution_json)
            rule_metadata_json=$(build_rule_metadata_json 'source-file-headers')
            emit_protocol_line 'blocked' 'edit_headers' 'source-file-headers' 'Non-test, non-.d.ts TypeScript source files staged outside dot-directories must include [META] and [WHY] in the first 10 lines.' "$resolution_json" "$rule_metadata_json"
            exit 1
        fi

        echo 'File headers passed'
        header_end_ms=$(now_ms)
        record_source_headers_check 'passed' "$((header_end_ms - header_start_ms))"
    fi
fi

# 3. docs-guardrail: 在测试前先挡住文档漂移
DOC_GUARDRAIL_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '^(README\.md|package\.json|docs/|src/cli/index\.ts|vitest\.config\.ts|vitest\.benchmark\.config\.ts|\.github/workflows/ci-gateway\.yml)$' || true)
docs_start_ms=$(now_ms)
if [ -n "$DOC_GUARDRAIL_FILES" ]; then
    echo 'Checking documentation guardrails...'
    npm run docs:check
    if [ $? -ne 0 ]; then
        docs_end_ms=$(now_ms)
        record_docs_guardrail_check 'failed' "$((docs_end_ms - docs_start_ms))"
        print_blocked_rule 'docs-guardrail' 'Documentation guardrails run whenever staged files touch README/package metadata, docs, CLI entrypoints, vitest config, or the CI gateway workflow.'
        echo 'TRIGGERED_BY:'
        printf '%s\n' "$DOC_GUARDRAIL_FILES"
        echo 'FIX: Run npm run docs:check and resolve the reported documentation drift.'
        echo 'FIX: Retry the commit after docs:check passes.'
        resolution_json=$(build_docs_guardrail_resolution_json)
        rule_metadata_json=$(build_rule_metadata_json 'docs-guardrail')
        emit_protocol_line 'blocked' 'rerun_docs_check' 'docs-guardrail' 'Documentation guardrails run whenever staged files touch README/package metadata, docs, CLI entrypoints, vitest config, or the CI gateway workflow.' "$resolution_json" "$rule_metadata_json"
        exit 1
    fi
    echo 'Documentation guardrails passed'
    docs_end_ms=$(now_ms)
    record_docs_guardrail_check 'passed' "$((docs_end_ms - docs_start_ms))"
else
    echo 'Documentation guardrails skipped'
    docs_end_ms=$(now_ms)
    record_docs_guardrail_check 'not_applicable' "$((docs_end_ms - docs_start_ms))" 'no-doc-guardrail-triggers'
fi

# 4. related-tests / package test fallback
related_start_ms=$(now_ms)
echo 'Running tests for staged files...'
if build_test_precheck_plan; then
    STAGED=$(printf '%s\n' "$STAGED_FILES" | grep -E "$SOURCE_FILE_PATTERN" || true)
    if [ -z "$STAGED" ]; then
        echo "No $TEST_TARGET_KIND files staged, skipping tests"
        related_end_ms=$(now_ms)
        record_related_tests_check 'not_applicable' "$((related_end_ms - related_start_ms))" 'no-matching-staged-source-files'
    else
        STAGED_COUNT=$(count_non_empty_lines "$STAGED")
        case "$TEST_STRATEGY" in
            vitest-related)
                if [ "$STAGED_COUNT" -le 3 ]; then
                    echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running related Vitest checks..."
                else
                    echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running related Vitest checks (single fork to reduce CPU load)..."
                fi
                ;;
            jest-related)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running related Jest checks..."
                ;;
            package-test)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running project test command fallback..."
                ;;
            pytest)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running pytest..."
                ;;
            go-test)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running go test ./..."
                ;;
            cargo-test)
                echo "Staged $STAGED_COUNT $TEST_TARGET_KIND file(s), running cargo test..."
                ;;
        esac

        run_related_tests
        if [ $? -ne 0 ]; then
            related_end_ms=$(now_ms)
            record_related_tests_check 'failed' "$((related_end_ms - related_start_ms))"
            print_blocked_rule 'related-tests' "$TEST_FAILURE_REASON"
            if [ -n "$TEST_STRATEGY" ]; then
                echo "TEST_STRATEGY: $TEST_STRATEGY"
            fi
            if [ -n "$TEST_COMMAND" ]; then
                echo "TEST_COMMAND: $TEST_COMMAND"
            fi
            if [ -n "$STAGED" ]; then
                echo 'TRIGGERED_SOURCE_FILES:'
                printf '%s\n' "$STAGED"
            fi
            echo 'FIX: Review the filtered failing test output and summary above.'
            echo 'FIX: Repair the code or tests, rerun one of the VERIFY commands, then retry the commit.'
            resolution_json=$(build_related_tests_resolution_json)
            rule_metadata_json=$(build_rule_metadata_json 'related-tests')
            emit_protocol_line 'blocked' 'rerun_verify_commands' 'related-tests' "$TEST_FAILURE_REASON" "$resolution_json" "$rule_metadata_json"
            exit 1
        fi

        echo 'Tests passed'
        related_end_ms=$(now_ms)
        record_related_tests_check 'passed' "$((related_end_ms - related_start_ms))"
    fi
else
    echo 'No supported staged-source test strategy detected, skipping tests'
    related_end_ms=$(now_ms)
    record_related_tests_check 'not_applicable' "$((related_end_ms - related_start_ms))" 'no-supported-staged-source-test-strategy'
fi

# 5. repo-local rule validation
rule_start_ms=$(now_ms)
echo "Running repo-local rule validation (mode: $RULE_HARD_GATE_MODE)..."
case "$RULE_HARD_GATE_MODE" in
    enforce)
        python3 scripts/validate-rules.py code
        VALIDATE_EXIT=$?
        rule_end_ms=$(now_ms)
        case "$VALIDATE_EXIT" in
            0)
                echo 'Rule validation passed'
                record_rule_validation_check 'passed' "$((rule_end_ms - rule_start_ms))" 'completed' 'false'
                ;;
            1)
                record_rule_validation_check 'failed' "$((rule_end_ms - rule_start_ms))" 'blocking-findings' 'false'
                print_blocked_rule 'repo-local-rule-validation' 'Repo-local rule validation found blocking P0 findings.'
                echo 'FIX: Run python3 scripts/validate-rules.py code to inspect the blocking findings.'
                echo 'FIX: Resolve the reported P0 issues, then retry the commit.'
                resolution_json=$(build_rule_validation_resolution_json)
                rule_metadata_json=$(build_rule_metadata_json 'repo-local-rule-validation')
                emit_protocol_line 'blocked' 'run_rule_validation' 'repo-local-rule-validation' 'Repo-local rule validation found blocking P0 findings.' "$resolution_json" "$rule_metadata_json"
                exit 1
                ;;
            2)
                echo 'WARNING: Rule validation reported warn-only P1 findings, continuing commit'
                record_rule_validation_check 'warn' "$((rule_end_ms - rule_start_ms))" 'warn-only-findings' 'true'
                ;;
            3)
                echo 'WARNING: Rule validation reported notice-only P2 findings, continuing commit'
                record_rule_validation_check 'warn' "$((rule_end_ms - rule_start_ms))" 'notice-only-findings' 'true'
                ;;
            4)
                record_rule_validation_check 'failed' "$((rule_end_ms - rule_start_ms))" 'dependencies-unavailable' 'false'
                print_blocked_rule 'repo-local-rule-validation-unavailable' 'Repo-local rule validation could not run because required dependencies are unavailable.'
                echo 'FIX: Restore the rule validation dependencies, then rerun python3 scripts/validate-rules.py code.'
                resolution_json=$(build_rule_validation_resolution_json)
                rule_metadata_json=$(build_rule_metadata_json 'repo-local-rule-validation-unavailable')
                emit_protocol_line 'blocked' 'run_rule_validation' 'repo-local-rule-validation-unavailable' 'Repo-local rule validation could not run because required dependencies are unavailable.' "$resolution_json" "$rule_metadata_json"
                exit 1
                ;;
            *)
                record_rule_validation_check 'failed' "$((rule_end_ms - rule_start_ms))" 'unexpected-exit' 'false'
                print_blocked_rule 'repo-local-rule-validation-unexpected' "Repo-local rule validation returned an unexpected exit code ($VALIDATE_EXIT)."
                echo 'FIX: Run python3 scripts/validate-rules.py code manually and inspect the failure.'
                resolution_json=$(build_rule_validation_resolution_json)
                rule_metadata_json=$(build_rule_metadata_json 'repo-local-rule-validation-unexpected')
                emit_protocol_line 'blocked' 'run_rule_validation' 'repo-local-rule-validation-unexpected' "Repo-local rule validation returned an unexpected exit code ($VALIDATE_EXIT)." "$resolution_json" "$rule_metadata_json"
                exit 1
                ;;
        esac
        ;;
    report-only|*)
        if [ "$RULE_HARD_GATE_MODE" != 'report-only' ]; then
            echo "WARNING: Unknown hard gate mode '$RULE_HARD_GATE_MODE', defaulting to report-only"
        fi
        run_rule_validation_report_only
        VALIDATE_EXIT=$?
        rule_end_ms=$(now_ms)
        if [ "$VALIDATE_EXIT" -eq 124 ]; then
            echo "INFO: Rule validation report-only completed (${RULE_REPORT_ONLY_TIMEOUT_SECONDS}s limit reached, non-blocking)"
            record_rule_validation_check 'warn' "$((rule_end_ms - rule_start_ms))" 'limit-reached' 'true'
        elif [ "$VALIDATE_EXIT" -ne 0 ]; then
            echo "INFO: Rule validation report-only command exited with $VALIDATE_EXIT (non-blocking), continuing commit"
            record_rule_validation_check 'warn' "$((rule_end_ms - rule_start_ms))" 'non-zero-exit' 'true'
        else
            echo 'Rule validation report-only completed'
            record_rule_validation_check 'passed' "$((rule_end_ms - rule_start_ms))" 'completed' 'true'
        fi
        ;;
esac

# 6. 真实场景测试模式（warn-only）
pattern_start_ms=$(now_ms)
echo 'Checking for real-world test patterns...'
STAGED_TEST_FILES=$(printf '%s\n' "$STAGED_FILES" | grep '\.test\.ts$' || true)
if [ -n "$STAGED_TEST_FILES" ]; then
    MISSING_REAL_PATTERN=0
    MISSING_REAL_PATTERN_FILES=''
    for file in $STAGED_TEST_FILES; do
        if [ ! -f "$file" ]; then
            continue
        fi
        if ! grep -qE '(spawn|execSync|execFileSync|mktemp|StdioServerTransport|PassThrough|createServer|listen)' "$file"; then
            echo "WARNING: $file does not appear to contain real-world invocation patterns (spawn, execSync, mktemp, StdioServerTransport, PassThrough, etc.)"
            MISSING_REAL_PATTERN=$((MISSING_REAL_PATTERN + 1))
            MISSING_REAL_PATTERN_FILES=$(printf '%s\n%s' "$MISSING_REAL_PATTERN_FILES" "$file" | sed '/^[[:space:]]*$/d')
        fi
    done
    if [ "$MISSING_REAL_PATTERN" -gt 0 ]; then
        echo ''
        echo 'Consider adding integration/E2E tests with real subprocess/transport calls.'
        echo 'See AGENTS.md Section 8.1 for the real-world validation threshold.'
        echo 'This is a warning only; commit will proceed.'
        echo ''
        pattern_end_ms=$(now_ms)
        record_real_world_test_patterns_check 'warn' "$((pattern_end_ms - pattern_start_ms))"
    else
        pattern_end_ms=$(now_ms)
        record_real_world_test_patterns_check 'passed' "$((pattern_end_ms - pattern_start_ms))"
    fi
else
    pattern_end_ms=$(now_ms)
    record_real_world_test_patterns_check 'not_applicable' "$((pattern_end_ms - pattern_start_ms))" 'no-staged-test-files'
fi

# 7. 生成 AI 饲料（warn-only）
ai_feed_start_ms=$(now_ms)
echo 'Generating AI feed...'
npx mycodemap generate --quiet >/dev/null 2>&1 &
if [ $? -ne 0 ]; then
    echo 'WARNING: Failed to start AI feed generation'
    ai_feed_end_ms=$(now_ms)
    record_ai_feed_check 'warn' "$((ai_feed_end_ms - ai_feed_start_ms))"
else
    ai_feed_end_ms=$(now_ms)
    record_ai_feed_check 'passed' "$((ai_feed_end_ms - ai_feed_start_ms))"
fi

echo 'Pre-commit checks passed'
emit_protocol_line 'allowed' 'commit' '' '' 'null' 'null'
exit 0
