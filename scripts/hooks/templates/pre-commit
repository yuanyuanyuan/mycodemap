#!/bin/sh
# Pre-commit hook: 运行测试和文件头检查

HOOK_SOURCE=".mycodemap/hooks/pre-commit"

print_blocked_rule() {
    rule_id="$1"
    reason="$2"

    echo "ERROR: Commit precheck blocked the commit."
    echo "RULE_ID: $rule_id"
    echo "HOOK_SOURCE: $HOOK_SOURCE"
    echo "WHY: $reason"
}

echo "Running pre-commit checks..."

# 1. 运行与变更相关的测试（失败即阻断）
# 只针对 staged 文件找相关测试，排除未暂存的实验代码，按变更量动态调整并发
echo "Running tests for staged files..."

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' || true)
if [ -z "$STAGED" ]; then
    echo "No TypeScript files staged, skipping tests"
else
    STAGED_COUNT=$(echo "$STAGED" | wc -l)

    if [ "$STAGED_COUNT" -le 3 ]; then
        echo "Staged $STAGED_COUNT TS file(s), running related tests..."
        VITEST_ARGS="related $STAGED --watch=false"
    else
        echo "Staged $STAGED_COUNT TS file(s), running related tests (single fork to reduce CPU load)..."
        VITEST_ARGS="related $STAGED --watch=false --pool=forks --poolOptions.forks.singleFork"
    fi

    if [ -f "node_modules/vitest/vitest.mjs" ]; then
        node node_modules/vitest/vitest.mjs $VITEST_ARGS
    else
        if [ ! -e "node_modules/vitest" ]; then
            VITEST_PACKAGE_DIR=$(find node_modules -type d -path '*/.pnpm/*/node_modules/vitest' | head -n 1)
            if [ -n "$VITEST_PACKAGE_DIR" ]; then
                ln -sfn "${VITEST_PACKAGE_DIR#node_modules/}" node_modules/vitest
            fi
        fi

        if [ -f "node_modules/vitest/vitest.mjs" ]; then
            node node_modules/vitest/vitest.mjs $VITEST_ARGS
        else
            VITEST_ENTRY=$(find node_modules -type f -path '*/.pnpm/*/node_modules/vitest/vitest.mjs' | head -n 1)
            if [ -z "$VITEST_ENTRY" ]; then
                VITEST_ENTRY=$(find node_modules -type f -path '*/.vitest-*/vitest.mjs' | head -n 1)
            fi

            if [ -n "$VITEST_ENTRY" ]; then
                node "$VITEST_ENTRY" $VITEST_ARGS
            else
                npx --yes vitest $VITEST_ARGS
            fi
        fi
    fi
    if [ $? -ne 0 ]; then
        print_blocked_rule \
            "related-tests" \
            "Related tests for the staged TypeScript files failed."
        if [ -n "$STAGED" ]; then
            echo "TRIGGERED_TS_FILES:"
            printf '%s\n' "$STAGED"
        fi
        echo "FIX: Review the failing test output above."
        echo "FIX: Repair the code or tests, rerun the related test command, then retry the commit."
        exit 1
    fi
fi

echo "Tests passed"

# 2. repo-local 规则校验（按 hard_gate.mode 决定 report-only / enforce）
RULE_CONFIG_PATH=".claude/rule-system.config.json"
RULE_HARD_GATE_MODE="report-only"
RULE_REPORT_ONLY_TIMEOUT_SECONDS="${RULE_REPORT_ONLY_TIMEOUT_SECONDS:-20}"

run_rule_validation_report_only() {
    python3 - <<'PY'
import os
import subprocess
import sys

timeout_value = os.environ.get("RULE_REPORT_ONLY_TIMEOUT_SECONDS", "20")

try:
    timeout_seconds = int(timeout_value)
except ValueError:
    timeout_seconds = 20

try:
    completed = subprocess.run(
        ["python3", "scripts/validate-rules.py", "code", "--report-only"],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        timeout=timeout_seconds,
    )
except subprocess.TimeoutExpired:
    sys.exit(124)

sys.exit(completed.returncode)
PY
}

if [ -f "$RULE_CONFIG_PATH" ]; then
    RULE_HARD_GATE_MODE=$(python3 - <<'PY'
import json
from pathlib import Path

config_path = Path(".claude/rule-system.config.json")

try:
    config = json.loads(config_path.read_text(encoding="utf-8"))
except Exception:
    print("report-only")
else:
    print(config.get("hard_gate", {}).get("mode", "report-only"))
PY
)
fi

echo "Running repo-local rule validation (mode: $RULE_HARD_GATE_MODE)..."
case "$RULE_HARD_GATE_MODE" in
    enforce)
        python3 scripts/validate-rules.py code
        VALIDATE_EXIT=$?
        case "$VALIDATE_EXIT" in
            0)
                echo "Rule validation passed"
                ;;
            1)
                print_blocked_rule \
                    "repo-local-rule-validation" \
                    "Repo-local rule validation found blocking P0 findings."
                echo "FIX: Run python3 scripts/validate-rules.py code to inspect the blocking findings."
                echo "FIX: Resolve the reported P0 issues, then retry the commit."
                exit 1
                ;;
            2)
                echo "WARNING: Rule validation reported warn-only P1 findings, continuing commit"
                ;;
            3)
                echo "WARNING: Rule validation reported notice-only P2 findings, continuing commit"
                ;;
            4)
                print_blocked_rule \
                    "repo-local-rule-validation-unavailable" \
                    "Repo-local rule validation could not run because required dependencies are unavailable."
                echo "FIX: Restore the rule validation dependencies, then rerun python3 scripts/validate-rules.py code."
                exit 1
                ;;
            *)
                print_blocked_rule \
                    "repo-local-rule-validation-unexpected" \
                    "Repo-local rule validation returned an unexpected exit code ($VALIDATE_EXIT)."
                echo "FIX: Run python3 scripts/validate-rules.py code manually and inspect the failure."
                exit 1
                ;;
        esac
        ;;
    report-only|*)
        if [ "$RULE_HARD_GATE_MODE" != "report-only" ]; then
            echo "WARNING: Unknown hard gate mode '$RULE_HARD_GATE_MODE', defaulting to report-only"
        fi
        run_rule_validation_report_only
        VALIDATE_EXIT=$?
        if [ "$VALIDATE_EXIT" -eq 124 ]; then
            echo "WARNING: Rule validation report-only timed out after ${RULE_REPORT_ONLY_TIMEOUT_SECONDS}s, continuing commit"
        elif [ "$VALIDATE_EXIT" -ne 0 ]; then
            echo "WARNING: Rule validation report-only command exited with $VALIDATE_EXIT, continuing commit"
        else
            echo "Rule validation report-only completed"
        fi
        ;;
esac

# 3. 检查 staged 文件数量（初始化 commit 除外）
# 规则: 单 commit 文件数量不能超过 10 个
# 例外: 如果包含文档类型文件，限制放宽到 20 个
MAX_FILES_PER_COMMIT=10
MAX_FILES_WITH_DOCS=20

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_FILE_COUNT=$(echo "$STAGED_FILES" | grep -c '^' || echo 0)

# 检查是否只包含以 . 开头的目录下的文件
# 如果是，则豁免数量和文件头检查
ONLY_DOT_DIRS=true
if [ -n "$STAGED_FILES" ]; then
    NON_DOT_FILES=$(echo "$STAGED_FILES" | grep -v '^\.' || true)
    if [ -n "$NON_DOT_FILES" ]; then
        ONLY_DOT_DIRS=false
    fi
fi

# 检查是否是初始化 commit（没有父提交）
IS_INITIAL_COMMIT=false
git rev-parse --verify HEAD >/dev/null 2>&1
if [ $? -ne 0 ]; then
    IS_INITIAL_COMMIT=true
fi

# 检查是否包含文档类型文件
# 文档类型: *.md, docs/* 目录下文件, README*, CHANGELOG*, LICENSE*
CONTAINS_DOC_FILES=false
if [ -n "$STAGED_FILES" ]; then
    DOC_FILES=$(echo "$STAGED_FILES" | grep -E '(\.md$|^docs/|^README|^CHANGELOG|^LICENSE)' || true)
    if [ -n "$DOC_FILES" ]; then
        CONTAINS_DOC_FILES=true
    fi
fi

# 根据是否包含文档类型文件设置限制
if [ "$CONTAINS_DOC_FILES" = "true" ]; then
    CURRENT_LIMIT=$MAX_FILES_WITH_DOCS
else
    CURRENT_LIMIT=$MAX_FILES_PER_COMMIT
fi

if [ "$ONLY_DOT_DIRS" = "true" ]; then
    echo "Note: Only dot-directory files staged, skipping count limit check"
elif [ "$STAGED_FILE_COUNT" -gt "$CURRENT_LIMIT" ] && [ "$IS_INITIAL_COMMIT" = "false" ]; then
    print_blocked_rule \
        "staged-file-limit" \
        "This non-initial commit stages $STAGED_FILE_COUNT files, which exceeds the allowed limit of $CURRENT_LIMIT."
    if [ "$CONTAINS_DOC_FILES" = "true" ]; then
        echo "FIX: This commit includes documentation files, so the higher limit is $MAX_FILES_WITH_DOCS files."
    else
        echo "FIX: Non-dot commits without documentation files must stay at or below $MAX_FILES_PER_COMMIT files."
    fi
    echo "FIX: Dot-directory-only commits are exempt from this rule."
    echo "FIX: Split the staged changes into smaller commits, then retry."
    echo "STAGED_FILES:"
    git diff --cached --name-only --diff-filter=ACM
    exit 1
fi

# 4. 检查文件头注释（只检查 staged 的 TS 源文件，豁免 . 开头目录）
echo "Checking file headers..."
if [ "$ONLY_DOT_DIRS" = "true" ]; then
    echo "Note: Only dot-directory files staged, skipping header check"
    STAGED_TS_FILES=""
else
    STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$' | grep -v '\.test\.ts$' | grep -v '\.d\.ts$')
fi

if [ -n "$STAGED_TS_FILES" ]; then
    MISSING_HEADERS=0

    for file in $STAGED_TS_FILES; do
        if [ ! -f "$file" ]; then
            continue
        fi

        HEAD_CONTENT=$(head -10 "$file")

        if ! echo "$HEAD_CONTENT" | grep -q '\[META\]'; then
            echo "ERROR: $file missing [META] comment"
            MISSING_HEADERS=$((MISSING_HEADERS + 1))
        fi

        if ! echo "$HEAD_CONTENT" | grep -q '\[WHY\]'; then
            echo "ERROR: $file missing [WHY] comment"
            MISSING_HEADERS=$((MISSING_HEADERS + 1))
        fi
    done

    if [ $MISSING_HEADERS -gt 0 ]; then
        print_blocked_rule \
            "source-file-headers" \
            "Non-test, non-.d.ts TypeScript source files staged outside dot-directories must include [META] and [WHY] in the first 10 lines."
        echo "FIX: Add these header lines at the top of each listed file:"
        echo "FIX: // [META] since:YYYY-MM | owner:team | stable:false"
        echo "FIX: // [WHY] Explain why this file exists"
        exit 1
    fi
fi

echo "File headers passed"

# 5a. 轻量真实验证检查（warn-only）
# 如果新增/修改了测试文件，检查是否包含真实调用模式
echo "Checking for real-world test patterns..."
STAGED_TEST_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.test\.ts$' || true)
if [ -n "$STAGED_TEST_FILES" ]; then
    MISSING_REAL_PATTERN=0
    for file in $STAGED_TEST_FILES; do
        if [ ! -f "$file" ]; then
            continue
        fi
        # 检查是否包含真实调用模式
        # 注意：StdioServerTransport + PassThrough 是真实 MCP transport 测试模式
        if ! grep -qE '(spawn|execSync|execFileSync|mktemp|StdioServerTransport|PassThrough|createServer|listen)' "$file"; then
            echo "WARNING: $file does not appear to contain real-world invocation patterns (spawn, execSync, mktemp, StdioServerTransport, PassThrough, etc.)"
            MISSING_REAL_PATTERN=$((MISSING_REAL_PATTERN + 1))
        fi
    done
    if [ $MISSING_REAL_PATTERN -gt 0 ]; then
        echo ""
        echo "Consider adding integration/E2E tests with real subprocess/transport calls."
        echo "See AGENTS.md Section 8.1 for the real-world validation threshold."
        echo "This is a warning only; commit will proceed."
        echo ""
    fi
fi

# 5. 检查文档与 CLI 护栏（仅在相关文件变更时阻断）
DOC_GUARDRAIL_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(README\.md|package\.json|docs/|src/cli/index\.ts|vitest\.config\.ts|vitest\.benchmark\.config\.ts|\.github/workflows/ci-gateway\.yml)$' || true)

if [ -n "$DOC_GUARDRAIL_FILES" ]; then
    echo "Checking documentation guardrails..."
    npm run docs:check
    if [ $? -ne 0 ]; then
        print_blocked_rule \
            "docs-guardrail" \
            "Documentation guardrails run whenever staged files touch README/package metadata, docs, CLI entrypoints, vitest config, or the CI gateway workflow."
        echo "TRIGGERED_BY:"
        printf '%s\n' "$DOC_GUARDRAIL_FILES"
        echo "FIX: Run npm run docs:check and resolve the reported documentation drift."
        echo "FIX: Retry the commit after docs:check passes."
        exit 1
    fi
fi

echo "Documentation guardrails passed"

# 6. 生成 AI 饲料（警告级，不阻断）
echo "Generating AI feed..."
npx mycodemap generate --quiet >/dev/null 2>&1 &
if [ $? -ne 0 ]; then
    echo "WARNING: Failed to start AI feed generation"
fi

echo "Pre-commit checks passed"
exit 0
