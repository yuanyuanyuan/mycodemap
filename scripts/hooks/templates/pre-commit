run_related_tests() {
    TEST_OUTPUT_FILE=$(mktemp "${TMPDIR:-/tmp}/codemap-related-tests-XXXXXX")
    FILTERED_TEST_OUTPUT_FILE=$(mktemp "${TMPDIR:-/tmp}/codemap-related-tests-filtered-XXXXXX")

    run_test_precheck_command

    RELATED_TEST_EXIT=$?
    SUPPRESSED_TEST_WARNING_COUNT=$(grep -c '^Contract tool "' "$TEST_OUTPUT_FILE" 2>/dev/null || true)
    grep -v '^Contract tool "' "$TEST_OUTPUT_FILE" >"$FILTERED_TEST_OUTPUT_FILE" || true
    if [ ! -s "$FILTERED_TEST_OUTPUT_FILE" ]; then
        cp "$TEST_OUTPUT_FILE" "$FILTERED_TEST_OUTPUT_FILE"
    fi

    if [ "$RELATED_TEST_EXIT" -ne 0 ]; then
        cat "$FILTERED_TEST_OUTPUT_FILE"
        extract_failed_test_file
        FAILED_TEST_HEADLINE=$(grep -m 1 -E '^ FAIL |^FAIL |^FAILED |^--- FAIL:' "$FILTERED_TEST_OUTPUT_FILE" || true)
        build_failed_test_verify_command
        build_related_test_failure_hint
        print_related_test_summary
    fi

    return "$RELATED_TEST_EXIT"
}

build_staged_file_limit_resolution_json() {
    STAGED_FILES_RAW="$STAGED_FILES" \
    CURRENT_LIMIT_VALUE="$CURRENT_LIMIT" \
    ATTEMPT_ID_VALUE="$ATTEMPT_ID" \
    python3 - <<'PY'
import json
import os
import re
import shlex
from collections import Counter, defaultdict

files = [line for line in os.environ.get('STAGED_FILES_RAW', '').splitlines() if line.strip()]
limit = int(os.environ.get('CURRENT_LIMIT_VALUE', '10') or '10')
attempt_id = os.environ.get('ATTEMPT_ID_VALUE', '')
ignore = {
    'src', 'scripts', 'tests', 'test', '__tests__', 'cli', 'dist', 'data', 'home', 'tmp', 'codemap',
    'json', 'ts', 'tsx', 'js', 'jsx', 'mjs', 'cjs', 'py', 'md', 'yml', 'yaml', 'sh', 'config'
}


def doc_file(path: str) -> bool:
    return path.endswith('.md') or path.startswith('docs/') or path.startswith('README') or path.startswith('CHANGELOG') or path.startswith('LICENSE')


def tokens(path: str):
    raw = re.findall(r'[A-Za-z0-9]+', path.lower())
    return {token for token in raw if token not in ignore and not token.isdigit()}


def anchor(path: str):
    lower = path.lower()
    token_set = tokens(path)
    if lower.startswith(('scripts/hooks/', '.githooks/', '.mycodemap/hooks/')) or 'hook' in token_set or 'hooks' in token_set:
        return 'hooks'
    if 'env' in token_set and 'contract' in token_set:
        return 'env-contract'
    if 'manifest' in token_set or 'package' in token_set:
        return 'manifest'
    if 'doctor' in token_set:
        return 'doctor'
    if doc_file(path):
        return 'docs'
    if token_set:
        return sorted(token_set)[0]
    return 'misc'

indexed = list(enumerate(files))
buckets = defaultdict(list)
for index, file_path in indexed:
    buckets[anchor(file_path)].append((index, file_path))

ordered_buckets = sorted(
    buckets.items(),
    key=lambda item: (-len(item[1]), min(index for index, _ in item[1])),
)

chunks = []
for bucket_name, items in ordered_buckets:
    paths = [path for _, path in sorted(items)]
    while paths:
        chunks.append({'anchor': bucket_name, 'files': paths[:limit]})
        paths = paths[limit:]


def scope_and_tag(chunk_anchor, paths):
    bucket_tokens = Counter()
    for path in paths:
        bucket_tokens.update(tokens(path))
    token_set = set(bucket_tokens)
    if 'env' in token_set and 'contract' in token_set:
        return 'env-contract', 'FEATURE', 'multi-language test command discovery'
    if 'hook' in token_set or 'hooks' in token_set or chunk_anchor == 'hooks':
        return 'hooks', 'REFACTOR', 'structured pre-commit protocol changes'
    if 'manifest' in token_set or 'package' in token_set or chunk_anchor == 'manifest':
        return 'manifest', 'FEATURE', 'test command detection changes'
    if all(doc_file(path) for path in paths):
        return 'docs', 'DOCS', 'documentation updates'
    if 'doctor' in token_set or chunk_anchor == 'doctor':
        return 'doctor', 'REFACTOR', 'doctor contract alignment'
    scope = chunk_anchor if chunk_anchor and chunk_anchor != 'misc' else 'changes'
    return scope, 'REFACTOR', 'split commit group'

suggested_groups = []
total_groups = len(chunks)
for index, chunk in enumerate(chunks, start=1):
    scope, tag, summary = scope_and_tag(chunk['anchor'], chunk['files'])
    if total_groups > 1:
        message = f'[{tag}] {scope}: {summary} ({index}/{total_groups})'
    else:
        message = f'[{tag}] {scope}: {summary}'
    agent_context = {
        'attempt_id': attempt_id,
        'plan_id': f'{attempt_id}-split-commit',
        'group_index': index,
        'group_count': total_groups,
        'resolution': 'split_commit',
    }
    suggested_groups.append({
        'group_index': index,
        'files': chunk['files'],
        'message': message,
        'commands': {
            'reset': 'git reset HEAD',
            'stage': 'git add ' + ' '.join(shlex.quote(path) for path in chunk['files']),
            'commit': 'git commit -m ' + shlex.quote(message),
            'commit_with_context': 'CODEMAP_AGENT_CONTEXT=' + shlex.quote(json.dumps(agent_context, separators=(",", ":"))) + ' git commit -m ' + shlex.quote(message),
        },
        'agent_context': agent_context,
    })

payload = {
    'type': 'split_commit',
    'current': len(files),
    'limit': limit,
    'reset_command': 'git reset HEAD',
    'suggested_groups': suggested_groups,
}
print(json.dumps(payload, separators=(',', ':')))
PY
}

