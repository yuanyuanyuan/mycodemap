#!/bin/sh
# Pre-commit hook: 运行测试和文件头检查

echo "Running pre-commit checks..."

# 1. 运行测试
echo "-> Running tests..."
npm test
if [ $? -ne 0 ]; then
    echo "ERROR: Tests failed, commit rejected"
    exit 1
fi
echo "All tests passed"

# 2. 检查文件头注释（只检查 staged 文件）
echo "-> Checking file headers..."

# 获取 node_modules 的路径
NODE_PATH=$(pwd)/node_modules

# 检查是否安装了必要的依赖
if [ ! -f "$NODE_PATH/.bin/tsc" ]; then
    echo "WARNING: TypeScript not found, skipping header check"
else
    # 获取 staged 的 .ts/.js 文件
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' | grep -v node_modules | grep -v dist | grep -v __tests__ | grep -v "\.test\." | grep -v "\.spec\.")

    # 如果没有 staged 的源文件，跳过检查
    if [ -z "$STAGED_FILES" ]; then
        echo "No source files staged, skipping header check"
    else
        # 统计变量
        TOTAL=0
        INVALID=0

        for file in $STAGED_FILES; do
            # 跳过不存在的文件（如删除的文件）
            if [ ! -f "$file" ]; then
                continue
            fi

            TOTAL=$((TOTAL + 1))

            # 检查文件头是否包含 [META] 或 [WHY]
            if ! head -n 20 "$file" | grep -qi '\[META\]\|\[WHY\]'; then
                echo "ERROR: E0008: $file - Missing [META] or [WHY] comment"
                INVALID=$((INVALID + 1))
            fi
        done

        echo ""
        echo "Total files checked: $TOTAL"
        echo "Invalid files: $INVALID"

        if [ $INVALID -gt 0 ]; then
            echo ""
            echo "ERROR: File header check failed. Please add [META] or [WHY] comment to the files above."
            exit 1
        fi

        echo "All file headers are valid"
    fi
fi

# 3. 生成 AI 饲料（异步执行）
echo "-> Generating AI feed..."
npx codemap generate --quiet &
echo "AI feed generation started in background"

echo "All pre-commit checks passed"
exit 0
