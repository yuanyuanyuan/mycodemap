#!/bin/sh
# Legacy Git hook shim: forward to the canonical CodeMap payload

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
CODEMAP_HOOK="$REPO_ROOT/.mycodemap/hooks/commit-msg"

if [ ! -x "$CODEMAP_HOOK" ]; then
  echo "ERROR: missing CodeMap hook payload: $CODEMAP_HOOK" >&2
  echo "FIX: Resync hook payloads with \`sh scripts/hooks/install-hooks.sh\` or \`mycodemap init -y\`." >&2
  exit 1
fi

"$CODEMAP_HOOK" "$@"
