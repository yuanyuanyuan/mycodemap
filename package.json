{
  "name": "codemap",
  "version": "0.1.0",
  "description": "TypeScript 代码地图工具 - 为 AI 辅助开发提供结构化上下文",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "codemap": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "sh scripts/hooks/install-hooks.sh"
  },
  "keywords": [
    "typescript",
    "codemap",
    "code-analysis",
    "ai",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "globby": "^14.0.0",
    "ora": "^8.0.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.55.0",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
