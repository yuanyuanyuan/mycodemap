{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "symbol", "file", "line", "type", "score"],
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符"
    },
    "symbol": {
      "type": "string",
      "description": "符号名称"
    },
    "file": {
      "type": "string",
      "description": "文件路径"
    },
    "line": {
      "type": "number",
      "description": "行号"
    },
    "type": {
      "type": "string",
      "enum": ["class", "function", "interface", "type", "variable", "constant", "module", "file", "unknown"],
      "description": "符号类型"
    },
    "score": {
      "type": "object",
      "required": ["heat", "confidence"],
      "properties": {
        "heat": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "热度分数"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "置信度"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "额外元数据"
    }
  }
}
